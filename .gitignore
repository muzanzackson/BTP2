# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ─── Environments ─────────────────────────────────────────────────────────────
venv/
.env/
*.env
.conda/

# ─── IDE & Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# ─── Logs (runtime-generated — never commit) ──────────────────────────────────
logs/
*.log

# ─── Generated outputs (runtime artifacts) ────────────────────────────────────
tree_visualization.html
last_npz_path.txt
temp_labels.json
temp_tree.nwk

# ─── Embedding outputs (large binary files) ───────────────────────────────────
embeddings/*.npz
embeddings/*.npy

# ─── UPGMA tree outputs ────────────────────────────────────────────────────────
trees/*.nwk

# ─── PyTorch dataset cache ────────────────────────────────────────────────────
data/cifar-10-batches-py/
data/cifar-100-python/
data/MNIST/
data/FashionMNIST/
data/stl10_binary/

# ─── Keep empty output folder stubs ──────────────────────────────────────────
!embeddings/.gitkeep
!trees/.gitkeep
!logs/.gitkeep
!assets/.gitkeep

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── R artifacts (inside lib/DefIn) ──────────────────────────────────────────
*.Rhistory
*.RData